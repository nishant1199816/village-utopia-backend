# Database (Render PostgreSQL or Neon.tech free)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/village_utopia?schema=public"

# Auth
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Razorpay (razorpay.com → Settings → API Keys)
RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxx"

# Email (Gmail App Password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
FROM_EMAIL="Village Utopia Cottages <stay@villageutopia.in>"

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
